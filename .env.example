# ---- Database ----
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/funnel_agent

# ---- Gemini (direct Google GenAI SDK; no LangChain) ----
GEMINI_API_KEY=your-gemini-api-key
# Model used for scoring (Stage B) and the decision engine. Override per env.
GEMINI_MODEL=gemini-2.5-flash

# ---- App ----
SITE_ID=default
APP_HOST=0.0.0.0
APP_PORT=8000

# ---- Going live: browser ingestion + safety ----
# Public write key required on /track & /identify (blank = disabled, dev-friendly).
TRACK_WRITE_KEY=
# Origins allowed to POST from the browser, comma-separated. In prod use your site,
# e.g. https://engageoagency.com,https://www.engageoagency.com
CORS_ALLOW_ORIGINS=*
# shadow = never actually send (stub + log); live = use real senders once configured.
EXECUTION_MODE=shadow

# ---- WhatsApp via Meta Cloud API (only used when EXECUTION_MODE=live) ----
META_WA_ACCESS_TOKEN=
META_WA_PHONE_NUMBER_ID=
META_WA_API_VERSION=v21.0
# text = only inside the 24h window; template = business-initiated outreach (needs an approved template)
META_WA_MESSAGE_TYPE=text
META_WA_TEMPLATE_NAME=
META_WA_TEMPLATE_LANG=en_US
# set false for zero-variable templates like hello_world
META_WA_TEMPLATE_BODY_PARAM=true

# ---- Deploy (Railway / Docker) ----
# The host injects PORT; the app binds it automatically. Apply schema.sql on
# container start (idempotent); set false if you manage the schema yourself.
RUN_SCHEMA_ON_STARTUP=true
